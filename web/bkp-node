async function getBalance(externalId) {
  const filter = encodeURIComponent(JSON.stringify({ external_id: { _eq: externalId } }));
  const u = await dFetch(`/items/app_users?filter=${filter}&limit=1`);
  const user = u?.data?.[0];

  const balance = Number(user?.points_balance || 0);

  const f2 = encodeURIComponent(JSON.stringify({ external_id: { _eq: externalId } }));
  const r = await dFetch(`/items/points_ledger?filter=${f2}&limit=50&sort=-created_at`);
  const history = r?.data || [];

  return { balance, history };
}
// Saldo por loja (usado para recompensas)
async function getStoreBalance(externalId, storeId) {
  const filter = encodeURIComponent(JSON.stringify({
    external_id: { _eq: externalId },
    store_id: { _eq: storeId }
  }));

  const r = await dFetch(`/items/points_ledger?filter=${filter}&limit=1000`);
  const history = r?.data || [];

  return history.reduce((sum, row) => {
    return sum + Number(row.points || 0);
  }, 0);
}

/* =========================
   STORE REWARDS (COM PROGRESSO)
========================= */
app.get("/api/stores/:id/rewards", async (req, res) => {
  try {
    const storeId = Number(req.params.id);
    const external_id = String(req.query.external_id || "").trim();

    if (!storeId || !external_id) {
      return res.status(400).json({
        ok: false,
        error: "Parâmetros inválidos"
      });
    }

    // calcula saldo do usuário nessa loja
    const balance = await getStoreBalance(external_id, storeId);

    // busca recompensas ativas da loja
    const rewardsRes = await dFetch(
      `/items/store_rewards?filter[store_id][_eq]=${storeId}&filter[active][_eq]=true`
    );

    const rewards = rewardsRes?.data || [];

    // adiciona progresso
    const enriched = rewards.map(r => {
      const cost = Number(r.points_cost || 0);

      return {
        id: r.id,
        title: r.title,
        discount_percent: r.discount_percent,
        points_cost: cost,
        user_points: balance,
        points_missing: cost > balance ? cost - balance : 0,
        can_redeem: balance >= cost
      };
    });

    return res.json({
      ok: true,
      store_id: storeId,
      store_balance: balance,
      rewards: enriched
    });

  } catch (e) {
    return res.status(500).json({
      ok: false,
      error: String(e.message || e)
    });
  }
});

/* =========================
   REDEEM REWARD (SIMPLES, PREPARADO PARA EVOLUIR)
========================= */
app.post("/api/rewards/redeem", async (req, res) => {
  try {
    const { external_id, reward_id } = req.body || {};

    if (!external_id || !reward_id) {
      return res.status(400).json({
        ok: false,
        error: "Parâmetros inválidos"
      });
    }

    // buscar reward
    const rewardRes = await dFetch(`/items/store_rewards/${reward_id}`);
    const reward = rewardRes?.data;

    if (!reward || reward.active === false) {
      return res.json({
        ok: false,
        message: "Recompensa indisponível"
      });
    }

    const storeId = reward.store_id;
    const cost = Number(reward.points_cost || 0);

    // calcular saldo na loja
    const balance = await getStoreBalance(external_id, storeId);

    if (balance < cost) {
      return res.json({
        ok: false,
        message: "Pontos insuficientes",
        store_balance: balance
      });
    }

    // descontar pontos (ledger negativo)
    await addLedger(external_id, storeId, -cost);

    const newBalance = balance - cost;

    return res.json({
      ok: true,
      message: `Resgate confirmado: ${reward.title}`,
      discount_percent: reward.discount_percent,
      points_used: cost,
      store_balance: newBalance,
      redeemed_at: nowSec()
    });

  } catch (e) {
    return res.status(500).json({
      ok: false,
      error: String(e.message || e)
    });
  }
});


