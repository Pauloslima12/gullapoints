/* =========================
   Helpers Directus
========================= */
async function dFetch(path, { method = "GET", body } = {}) {
  if (!DIRECTUS_URL || !DIRECTUS_TOKEN) {
    throw new Error("DIRECTUS_URL ou DIRECTUS_TOKEN não definidos");
  }

  const url = `${DIRECTUS_URL}${path}`;
  const res = await fetch(url, {
    method,
    headers: {
      Authorization: `Bearer ${DIRECTUS_TOKEN}`,
      "Content-Type": "application/json",
      "Cache-Control": "no-cache",
      Pragma: "no-cache",
    },
    body: body ? JSON.stringify(body) : undefined,
  });

  const txt = await res.text();
  let json = {};
  try { json = txt ? JSON.parse(txt) : {}; } catch { json = { raw: txt }; }

  if (!res.ok) {
    throw new Error(`Directus ${res.status}: ${JSON.stringify(json)}`);
  }

  return json;
}

const nowSec = () => Math.floor(Date.now() / 1000);

function parseStoreIdFromPayload(payload) {
  if (!payload || typeof payload !== "string") return null;
  const parts = payload.trim().split(":");
  if (parts.length !== 3) return null;
  if (parts[0] !== "GULLA" || parts[1] !== "STORE") return null;
  const id = Number(parts[2]);
  return Number.isFinite(id) ? id : null;
}

async function getOrCreateUser(externalId) {
  const ext = (externalId || "").trim();
  if (!ext) throw new Error("external_id ausente");

  const filter = encodeURIComponent(JSON.stringify({ external_id: { _eq: ext } }));
  const existing = await dFetch(`/items/app_users?filter=${filter}&limit=1`);
  if (existing?.data?.length) return existing.data[0];

  const created = await dFetch(`/items/app_users`, {
    method: "POST",
    body: { external_id: ext, points_balance: 0 },
  });
  return created.data;
}

async function updateUserBalance(externalId, newBalance) {
  const filter = encodeURIComponent(JSON.stringify({ external_id: { _eq: externalId } }));
  const existing = await dFetch(`/items/app_users?filter=${filter}&limit=1`);
  const row = existing?.data?.[0];
  if (!row) return;

  await dFetch(`/items/app_users/${row.id}`, {
    method: "PATCH",
    body: { points_balance: Number(newBalance) || 0 },
  });
}

async function getStore(storeId) {
  const r = await dFetch(`/items/stores/${storeId}`);
  return r.data;
}

async function getScanLimit(externalId, storeId) {
  const filter = encodeURIComponent(JSON.stringify({
    external_id: { _eq: externalId },
    store_id: { _eq: storeId }
  }));
  const r = await dFetch(`/items/scan_limits?filter=${filter}&limit=1`);
  return r?.data?.[0] || null;
}

async function upsertScanLimit(externalId, storeId) {
  const row = await getScanLimit(externalId, storeId);
  const t = nowSec();

  if (!row) {
    await dFetch(`/items/scan_limits`, {
      method: "POST",
      body: { external_id: externalId, store_id: storeId, last_scan_at: t }
    });
    return;
  }

  await dFetch(`/items/scan_limits/${row.id}`, {
    method: "PATCH",
    body: { last_scan_at: t }
  });
}

async function addLedger(externalId, storeId, points) {
  await dFetch(`/items/points_ledger`, {
    method: "POST",
    body: {
      external_id: externalId,
      store_id: storeId,
      points: Number(points) || 0,
      created_at: nowSec(),
    }
  });
}



