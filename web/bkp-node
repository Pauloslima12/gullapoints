/* =========================
   SCAN QR
========================= */
app.post("/api/points/scan", async (req, res) => {
  try {
    const { payload, external_id } = req.body || {};
    const storeId = parseStoreIdFromPayload(payload);
    if (!storeId) return res.status(400).json({ ok: false, error: "QR inválido" });

    const ext = String(external_id || "").trim();
    if (!ext) return res.status(400).json({ ok: false, error: "external_id ausente" });

    await getOrCreateUser(ext);

    const store = await getStore(storeId);
    if (store?.active === false) {
      return res.status(403).json({ ok: false, error: "Loja inativa" });
    }

    const points = Number(store?.points_per_scan ?? 48);
    const cooldownHours = Number(store?.cooldown_hours ?? 24);

    const limit = await getScanLimit(ext, storeId);
    if (limit?.last_scan_at) {
      const diffHours = (nowSec() - Number(limit.last_scan_at)) / 3600;
      if (diffHours < cooldownHours) {
        const waitMin = Math.ceil((cooldownHours - diffHours) * 60);
        const bal = await getBalance(ext);
        return res.json({
          ok: false,
          message: `Você já resgatou hoje. Tente novamente em ~${waitMin} min.`,
          balance: bal.balance,
        });
      }
    }

    await addLedger(ext, storeId, points);
    await upsertScanLimit(ext, storeId);

    const balBefore = await getBalance(ext);
    const newBalance = (Number(balBefore.balance) || 0) + points;
    await updateUserBalance(ext, newBalance);

    const bal = await getBalance(ext);
    return res.json({
      ok: true,
      message: `+${points} GullaPoints em ${store?.name || "loja"}`,
      pointsAdded: points,
      balance: bal.balance,
      store: { id: storeId, name: store?.name || "" },
    });

  } catch (e) {
    return res.status(500).json({ ok: false, error: String(e.message || e) });
  }
});

