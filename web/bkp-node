/* =========================
   Invoices (SQLite local)
========================= */
const db = new Database("pay.db");
db.exec(`
  CREATE TABLE IF NOT EXISTS invoices (
    id TEXT PRIMARY KEY,
    token TEXT NOT NULL,
    amount TEXT NOT NULL,
    memo TEXT,
    expires_at INTEGER NOT NULL,
    payee TEXT NOT NULL,
    status TEXT NOT NULL DEFAULT 'pending',
    created_at INTEGER NOT NULL
  );
`);

app.post("/api/invoices", (req, res) => {
  const { token = "USDT", amount, memo = "", payee = "gulla", ttl_seconds = 900 } = req.body || {};
  if (!amount) return res.status(400).json({ error: "amount required" });

  const id = crypto.randomBytes(6).toString("hex").toUpperCase();
  const created_at = nowSec();
  const expires_at = created_at + Math.max(60, Math.min(86400, Number(ttl_seconds)));

  db.prepare(`
    INSERT INTO invoices (id, token, amount, memo, expires_at, payee, status, created_at)
    VALUES (?, ?, ?, ?, ?, ?, 'pending', ?)
  `).run(id, token, String(amount), memo, expires_at, String(payee), created_at);

  res.json({
    id,
    link: `https://pay.gullapay.com.br/i/${id}`,
    status: "pending",
    expires_at
  });
});

